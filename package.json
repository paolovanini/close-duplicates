    "version": "node version-bump.mjs",
    "publish": "npm run build && npm run version && node push-to-github.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@types/node": "^25.5.0",
    "esbuild": "0.27.4",
